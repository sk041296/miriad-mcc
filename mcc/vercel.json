{
  "buildCommand": "",
  "outputDirectory": ".",
  "functions": {
    "api/parse-eap.js": { "maxDuration": 60 },
    "api/verificar-import.js": { "maxDuration": 15 },
    "api/upload.js": { "maxDuration": 30 },
    "api/notificar.js": { "maxDuration": 60 }
  },
  "crons": [
    { "path": "/api/notificar", "schedule": "0 11 * * *" }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
